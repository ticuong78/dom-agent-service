{
  "name": "dom-agent-service",
  "packageManager": "yarn@4.16.0",
  "private": true,
  "scripts": {
    "add:server": "yarn workspace @dom-agent-service/server add",
    "add:wind-shield": "yarn workspace @dom-agent-service/wind-shield add",
    "remove:server": "yarn workspace @dom-agent-service/server remove",
    "remove:wind-shield": "yarn workspace @dom-agent-service/wind-shield remove",
    "dev:server": "yarn workspace @dom-agent-service/server run dev",
    "dev:wind-shield": "yarn workspace @dom-agent-service/wind-shield run dev",
    "build:server": "yarn workspace @dom-agent-service/server run build",
    "build:wind-shield": "yarn workspace @dom-agent-service/wind-shield run build"
  },
  "workspaces": [
    "packages/**/*"
  ],
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
